      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Banners",
      "blocks": {
        "slide_1": {
          "type": "slide",
          "settings": {
            "media_type": "image"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>SEASON 26</p>",
            "type_preset": "h2",
            "max_width": "narrow"
          }
        },
        "button_1": {
          "type": "button",
          "settings": {
            "label": "Shop all",
            "link": "shopify://collections/all"
          }
        }
      },
      "block_order": ["slide_1", "text_1", "button_1"],
      "settings": {
        "autoplay": true,
        "autoplay_speed": 5,
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "flex-end",
        "gap": 24,
        "section_height": "custom",
        "section_height_custom": 77,
        "color_scheme": "scheme-5",
        "toggle_overlay": true,
        "overlay_color": "#12121266",
        "overlay_style": "gradient",
        "padding-block-start": 100,
        "padding-block-end": 72
      }
    }
  ]
}
{% endschema %}
