<div class="whatsapp-button-wrapper" {{ block.shopify_attributes }}>
  {%- assign whatsapp_number = block.settings.whatsapp_number | default: '1234567890' -%}
  {%- assign whatsapp_text = block.settings.text | default: 'Chat on Whatsapp for Size Customisation' -%}
  {%- assign product_title = product.title | url_encode -%}
  {%- assign whatsapp_url = 'https://wa.me/' | append: whatsapp_number | append: '?text=Hi,%20I%20need%20size%20customisation%20for%20' | append: product_title -%}

  <a href="{{ whatsapp_url }}" target="_blank" rel="noopener noreferrer" class="whatsapp-button-link">
    <div class="whatsapp-button-inner">
      <svg class="whatsapp-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="32px" height="32px">
        <path fill="#4caf50" d="M41.4,7.8C36.9,3.3,30.9,0.8,24.6,0.8C11.5,0.8,0.8,11.5,0.8,24.6c0,4.2,1.1,8.3,3.2,11.9L0,48l11.8-3.1 c3.5,1.9,7.4,2.9,11.5,2.9h0c13.1,0,23.8-10.7,23.8-23.8C47.2,17.7,44.7,11.7,41.4,7.8z"/>
        <path fill="#fafafa" d="M23.3,44h0c-3.6,0-7.1-0.9-10.2-2.7l-0.7-0.4l-7.6,2l2-7.4l-0.4-0.7c-2-3.2-3.1-6.9-3.1-10.7 c0-11,8.9-19.9,19.9-19.9c5.3,0,10.3,2.1,14.1,5.8s5.8,8.7,5.8,14.1C43.2,35.1,34.3,44,23.3,44z"/>
        <path fill="#4caf50" d="M34.2,28c-0.6-0.3-3.5-1.7-4.1-1.9c-0.6-0.2-1-0.3-1.4,0.3c-0.4,0.6-1.6,1.9-1.9,2.3c-0.3,0.4-0.7,0.5-1.3,0.2 c-0.6-0.3-2.5-0.9-4.8-3c-1.8-1.6-3-3.6-3.4-4.2c-0.4-0.6-0.1-0.9,0.2-1.2c0.3-0.3,0.6-0.7,0.9-1c0.3-0.3,0.4-0.6,0.6-1 c0.2-0.4,0.1-0.7-0.1-1c-0.2-0.3-1.4-3.4-1.9-4.7c-0.5-1.2-1-1-1.4-1c-0.4,0-0.8,0-1.2,0s-1,0.1-1.6,0.7c-0.6,0.6-2.2,2.2-2.2,5.3 c0,3.1,2.3,6.1,2.6,6.5c0.3,0.4,4.4,6.8,10.7,9.5c1.5,0.6,2.7,1,3.6,1.3c1.5,0.5,2.9,0.4,4,0.2c1.2-0.2,3.5-1.4,4-2.8 C35.4,29.3,35.4,28.2,34.2,28z"/>
      </svg>
      <span class="whatsapp-button-text">{{ whatsapp_text }}</span>
    </div>
  </a>
</div>

{% style %}
  .whatsapp-button-wrapper {
    margin-top: 16px;
    margin-bottom: 16px;
    width: 100%;
  }

  .whatsapp-button-link {
    display: inline-block;
    text-decoration: none;
    width: 100%;
  }

  .whatsapp-button-inner {
    background-color: #e5f5db; /* Light green background matching screenshot */
    border-radius: 4px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    box-sizing: border-box;
    transition: background-color 0.2s ease;
  }

  .whatsapp-button-inner:hover {
    background-color: #d8eed0;
  }

  .whatsapp-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    filter: drop-shadow(0px 1px 2px rgba(0,0,0,0.1));
  }

  .whatsapp-button-text {
    color: #408933; /* Dark green text */
    font-size: 14px;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    text-decoration-color: #408933;
  }
{% endstyle %}

{% schema %}
{
  "name": "WhatsApp Customisation",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number",
      "info": "Include country code without '+' (e.g., 1234567890)",
      "default": "1234567890"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Button Text",
      "default": "Chat on Whatsapp for Size Customisation"
    }
  ],
  "presets": [
    {
      "name": "WhatsApp Customisation"
    }
  ]
}
{% endschema %}
