<tab-system class="tab-system spacing-style" {{ block.shopify_attributes }}>
  <div class="tab-headers-scroll">
    <div class="tab-headers"></div>
  </div>
  <div class="tab-contents"></div>
  
  <div class="shipping-features-widget" style="border: 1px solid var(--color-border); border-radius: 16px; padding: 24px; background-color: var(--color-background); margin-top: 16px; margin-bottom: 24px; box-shadow: 0 4px 12px rgba(var(--color-foreground-rgb), 0.02);">
    <div class="features-columns" style="display: grid; grid-template-columns: repeat(3, 1fr); align-items: center; justify-items: center;">
      <div class="feature-item" style="text-align: center; width: 100%; display: flex; flex-direction: column; align-items: center;">
        <div class="feature-icon-wrapper" style="width: 42px; height: 42px; border-radius: 12px; background-color: rgb(var(--color-foreground-rgb) / 0.05); display: flex; align-items: center; justify-content: center; margin-bottom: 12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-foreground)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </div>
        <span style="font-size: 9px; font-weight: 600; color: var(--color-foreground-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px;">SHIPS IN</span>
        <span style="font-size: 13px; font-weight: 700; color: var(--color-foreground);">24 Hours</span>
      </div>
      <div class="feature-divider" style="width: 1px; height: 50px; background-color: var(--color-border); opacity: 0.7;"></div>
      <div class="feature-item" style="text-align: center; width: 100%; display: flex; flex-direction: column; align-items: center;">
        <div class="feature-icon-wrapper" style="width: 42px; height: 42px; border-radius: 12px; background-color: rgb(var(--color-foreground-rgb) / 0.05); display: flex; align-items: center; justify-content: center; margin-bottom: 12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-foreground)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <span style="font-size: 9px; font-weight: 600; color: var(--color-foreground-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px;">DELIVERY</span>
        <span style="font-size: 13px; font-weight: 700; color: var(--color-foreground);">3–7 Days</span>
      </div>
      <div class="feature-divider" style="width: 1px; height: 50px; background-color: var(--color-border); opacity: 0.7;"></div>
      <div class="feature-item" style="text-align: center; width: 100%; display: flex; flex-direction: column; align-items: center; padding: 0 4px;">
        <div class="feature-icon-wrapper" style="width: 42px; height: 42px; border-radius: 12px; background-color: rgb(var(--color-foreground-rgb) / 0.05); display: flex; align-items: center; justify-content: center; margin-bottom: 12px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-foreground)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"></polyline>
            <polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
        </div>
        <span style="font-size: 9px; font-weight: 600; color: var(--color-foreground-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px;">RETURNS</span>
        <span style="font-size: 11px; font-weight: 700; color: var(--color-foreground); line-height: 1.3;">Easy 7-Day Return & Exchange</span>
      </div>
    </div>
  </div>

  <div class="share-and-help-wrapper" style="display: flex; align-items: center; justify-content: space-between; margin-top: 16px; margin-bottom: 16px; padding: 0 4px; flex-wrap: wrap; gap: 16px;">
    {%- render 'social-links', style: 'row', title: 'Share:' -%}
    <a href="https://wa.me/911234567890" target="_blank" rel="noopener noreferrer" class="help-link" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-foreground); text-decoration: underline; font-weight: 500; font-size: 14px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>
      Need help?
    </a>
  </div>
  
  <div style="display: none;" data-tab-sources>
    {% content_for 'blocks' %}
  </div>
</tab-system>

<script>
  if (!customElements.get('tab-system')) {
    class TabSystem extends HTMLElement {
      connectedCallback() {
        const headersContainer = this.querySelector('.tab-headers');
        const contentsContainer = this.querySelector('.tab-contents');
        
        // Wait a tick to make sure child blocks are rendered inside the hidden div
        setTimeout(() => {
          const tabs = this.querySelectorAll('[data-tab-sources] .tab-item-data');
          
          headersContainer.innerHTML = '';
          contentsContainer.innerHTML = '';
          
          tabs.forEach((tab, index) => {
            const title = tab.dataset.title;
            const id = tab.dataset.id;
            
            // Create tab button
            const button = document.createElement('button');
            button.type = 'button';
            button.className = `tab-button${index === 0 ? ' active' : ''}`;
            button.textContent = title;
            button.setAttribute('data-tab-id', id);
            
            button.addEventListener('click', () => {
              this.setActiveTab(id);
            });
            
            headersContainer.appendChild(button);
            
            // Clone or move content
            const content = tab.querySelector('.tab-content-inner');
            if (content) {
              const contentClone = content.cloneNode(true);
              contentClone.setAttribute('data-tab-content-id', id);
              if (index === 0) {
                contentClone.classList.add('active');
              } else {
                contentClone.classList.remove('active');
              }
              contentsContainer.appendChild(contentClone);
            }
          });
        }, 0);
      }
      
      setActiveTab(id) {
        this.querySelectorAll('.tab-button').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-tab-id') === id);
        });
        this.querySelectorAll('.tab-content-inner').forEach(content => {
          content.classList.toggle('active', content.getAttribute('data-tab-content-id') === id);
        });
      }
    }
    customElements.define('tab-system', TabSystem);
  }
</script>

{% style %}
  .tab-system {
    width: 100%;
    margin-top: 24px;
    margin-bottom: 24px;
  }

  .tab-headers-scroll {
    overflow-x: auto;
    width: 100%;
    border-bottom: 1px solid #e0e0e0;
    -webkit-overflow-scrolling: touch;
  }

  .tab-headers-scroll::-webkit-scrollbar {
    display: none; /* Hide scrollbar for Chrome, Safari and Opera */
  }

  .tab-headers {
    display: flex;
    gap: 32px;
    padding-bottom: 0;
    white-space: nowrap;
  }

  .tab-button {
    background: none;
    border: none;
    padding: 12px 0;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999999;
    cursor: pointer;
    position: relative;
    transition: color 0.2s ease;
  }

  .tab-button:hover {
    color: #000000;
  }

  .tab-button::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #000000;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .tab-button.active {
    color: #000000;
  }

  .tab-button.active::after {
    transform: scaleX(1);
  }

  .tab-contents {
    padding-top: 24px;
    padding-bottom: 12px;
  }

  .tab-content-inner {
    display: none;
    opacity: 0;
    transition: opacity 0.25s ease-in-out;
  }

  .tab-content-inner.active {
    display: block;
    opacity: 1;
  }
{% endstyle %}

{% schema %}
{
  "name": "Product Tabs",
  "tag": null,
  "class": "product-tabs-wrapper",
  "blocks": [
    {
      "type": "_tab"
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Add Tabs inside this block to render a horizontal tab system."
    }
  ],
  "presets": [
    {
      "name": "Product Tabs",
      "blocks": {
        "tab-1": {
          "type": "_tab",
          "settings": {
            "title": "Description"
          }
        },
        "tab-2": {
          "type": "_tab",
          "settings": {
            "title": "Shipping"
          }
        }
      },
      "block_order": ["tab-1", "tab-2"]
    }
  ]
}
{% endschema %}
